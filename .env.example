# Copy to .env and fill in values. Keep .env out of version control.

NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000

# Must match the Vite app origin(s) — comma-separated for production
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Supabase (Postgres)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# User JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin JWT
ADMIN_JWT_SECRET=
ADMIN_REFRESH_SECRET=
ADMIN_JWT_EXPIRES_IN=15m
ADMIN_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# WhatsApp — same business number as storefront fallback (frontend: VITE_WHATSAPP_NUMBER)
WHATSAPP_NUMBER=

# Session (Passport Google)
SESSION_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=

# Optional seed (scripts/seedAdmin.js)
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
